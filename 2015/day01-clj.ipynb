    "(def input (str (slurp \"input/1.txt\")))\n",
    "(defn delta [x]\n",
    "    (if (= x \\() 1 -1))\n",
    "\n",
    "(defn first-basement [idx floor deltas]\n",
    "    (if (= -1 floor)\n",
    "        idx\n",
    "        (recur \n",
    "         (inc idx)\n",
    "         (+ floor (first deltas)) \n",
    "         (rest deltas))))\n",
    "(defn append-new-floor [v delta]\n",
    "    (let [floor (last v)]\n",
    "        (conj v (+ floor delta))))\n",
    "\n",
    "\n",
    "(time (do\n",
    "(def deltas (->>\n",
    "    input\n",
    "    (map delta)))\n",
    "\n",
    "(def part1 (apply + deltas))\n",
    "(def part2 (first-basement 0 0 deltas))\n",
    "          ))\n",
    "[part1 part2]"
   ]
